{
  "name": "uxguard-portfolio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "VITE_API_PROXY=http://127.0.0.1:8001 vite",
    "dev:vercel": "vercel dev --listen 5174",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "UXGUARD_TEST=1 node --test api/_lib/billing/billing.test.js api/_lib/resume/schema.test.js api/_lib/resume/extraction.test.js api/_lib/resume/quality-pdf.test.js api/_lib/career/schema.test.js api/_lib/hiring/match.test.js api/_lib/testlab/testlab.test.js",
    "testlab:worker": "node scripts/testlab-worker.mjs",
    "lint": "npm run typecheck"
  },
  "dependencies": {
    "@tiptap/extension-color": "^3.28.0",
    "@tiptap/extension-font-family": "^3.28.0",
    "@tiptap/extension-link": "^3.28.0",
    "@tiptap/extension-text-align": "^3.28.0",
    "@tiptap/extension-text-style": "^3.28.0",
    "@tiptap/extension-underline": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@vercel/blob": "^2.5.0",
    "dompurify": "^3.4.12",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.12.0",
    "openai": "^4.104.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "playwright": "^1.61.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vercel/node": "^5.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
